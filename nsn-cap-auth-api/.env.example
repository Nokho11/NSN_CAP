# --- Upstash Redis (stockage des comptes) ---
# Peut être la même base que nsn-cap-whatsapp-bot, ou une base séparée.
UPSTASH_REDIS_REST_URL=https://xxxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Sécurité ---
# Génère une longue chaîne aléatoire (ex. openssl rand -hex 32) — garde-la secrète.
JWT_SECRET=change-moi-en-une-longue-chaine-aleatoire

# Mot de passe que TOI seule connais, pour débloquer l'accès d'un client
# après confirmation d'un paiement Wave/Orange Money (endpoint /api/grant-access).
ADMIN_SECRET=change-moi-aussi

# URL exacte de ton site (nsn-cap-site) une fois déployé, pour restreindre le CORS.
CORS_ORIGIN=https://nsn-cap-site.vercel.app
