# Copie ce fichier en .env.local pour tester en local (vercel dev),
# et renseigne les mêmes valeurs dans Vercel > Project > Settings > Environment Variables.

# --- Meta / WhatsApp Cloud API ---
# Trouvés dans developers.facebook.com > ton App > WhatsApp > API Setup
WHATSAPP_TOKEN=EAAxxxxxxxxxxxxxxxxxxxxxxxxxxxx
WHATSAPP_PHONE_NUMBER_ID=123456789012345

# Choisi par toi-même (une phrase secrète quelconque) — à renseigner aussi
# dans la configuration du Webhook sur developers.facebook.com
VERIFY_TOKEN=sirr-explorer-verify-2026

# --- Upstash Redis (stockage de la progression utilisateur) ---
# Crée une base gratuite sur https://upstash.com puis copie ces deux valeurs
# depuis l'onglet "REST API" de ta base.
UPSTASH_REDIS_REST_URL=https://xxxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxx
